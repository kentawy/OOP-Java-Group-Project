<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.oopjavagroupproject.HelloController">
    <tabs>
        <!-- Home/Settings Tab -->
        <Tab text="%tab.home">
            <content>
                <BorderPane>
                    <center>
                        <VBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Label styleClass="home-title-label" text="%home.title" />
                                <GridPane hgap="20" vgap="20" prefWidth="420.0" prefHeight="180.0">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Button onAction="#goToStudentsTab" prefHeight="50.0" prefWidth="200.0" text="%home.button.students" />
                                        <Button onAction="#goToFacultiesTab" prefHeight="50.0" prefWidth="200.0" text="%home.button.faculties" GridPane.columnIndex="1" />
                                        <Button onAction="#goToRoomsTab" prefHeight="50.0" prefWidth="200.0" text="%home.button.rooms" GridPane.rowIndex="1" />
                                        <Button onAction="#goToContractsTab" prefHeight="50.0" prefWidth="200.0" text="%home.button.contracts" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </center>
                    <bottom>
                        <HBox alignment="CENTER_RIGHT" prefHeight="40.0" spacing="10.0" BorderPane.alignment="CENTER">
                            <padding><Insets bottom="10.0" right="10.0" /></padding>
                            <children>
                                <Label text="%home.label.theme" />
                                <ComboBox fx:id="themeComboBox" prefWidth="150.0" />
                                <Label text="%home.label.language" />
                                <ComboBox fx:id="languageComboBox" prefWidth="150.0" />
                            </children>
                        </HBox>
                    </bottom>
                </BorderPane>
            </content>
        </Tab>

        <!-- Students Tab -->
        <Tab fx:id="studentsTab" text="%tab.students">
            <content>
                <BorderPane>
                    <top>
                        <VBox prefHeight="80.0" spacing="10.0" BorderPane.alignment="CENTER">
                            <padding><Insets left="10.0" right="10.0" top="10.0" /></padding>
                            <children>
                                <Label text="%students.search.title"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <TextField fx:id="searchNameField" promptText="%students.search.name.prompt" prefWidth="250.0" />
                                        <ComboBox fx:id="searchFacultyComboBox" promptText="%students.search.faculty.prompt" prefWidth="250.0" />
                                        <Button onAction="#searchStudents" text="%button.search" />
                                        <Button onAction="#clearSearch" text="%button.clear_search" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </top>
                    <center>
                        <TableView fx:id="studentTable" BorderPane.alignment="CENTER">
                            <columns>
                                <TableColumn fx:id="idColumn" prefWidth="50.0" text="%students.table.id" />
                                <TableColumn fx:id="fullNameColumn" prefWidth="250.0" text="%students.table.fullname" />
                                <TableColumn fx:id="genderColumn" prefWidth="100.0" text="%students.table.gender" />
                                <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="%students.table.phone" />
                                <TableColumn fx:id="facultyColumn" prefWidth="200.0" text="%students.table.faculty" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <BorderPane.margin><Insets left="10.0" right="10.0" /></BorderPane.margin>
                        </TableView>
                    </center>
                    <bottom>
                        <VBox alignment="TOP_CENTER" prefHeight="150.0" spacing="10.0" BorderPane.alignment="CENTER">
                            <children>
                                <Label text="%students.title"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <TextField fx:id="fullNameField" promptText="%students.form.name.prompt" prefWidth="250.0" />
                                        <ComboBox fx:id="genderComboBox" promptText="%students.form.gender.prompt" prefWidth="120.0" />
                                        <TextField fx:id="phoneField" promptText="%students.form.phone.prompt" prefWidth="150.0" />
                                        <ComboBox fx:id="facultyComboBox" promptText="%students.form.faculty.prompt" prefWidth="250.0" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button onAction="#addStudent" prefWidth="120.0" text="%button.add" />
                                        <Button onAction="#updateStudent" prefWidth="120.0" text="%button.update" />
                                        <Button onAction="#deleteStudent" prefWidth="120.0" text="%button.delete" />
                                        <Button onAction="#clearInputFields" prefWidth="120.0" text="%button.clear" />
                                    </children>
                                </HBox>
                            </children>
                            <padding><Insets bottom="10.0" /></padding>
                        </VBox>
                    </bottom>
                </BorderPane>
            </content>
        </Tab>

        <!-- Faculties Tab -->
        <Tab fx:id="facultiesTab" text="%tab.faculties">
            <content>
                <BorderPane>
                    <center>
                        <TableView fx:id="facultyTableView" BorderPane.alignment="CENTER">
                            <columns>
                                <TableColumn fx:id="facultyIdColumn" prefWidth="100.0" text="%faculties.table.id" />
                                <TableColumn fx:id="facultyNameColumn" prefWidth="500.0" text="%faculties.table.name" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <BorderPane.margin><Insets top="10.0" right="10.0" bottom="10.0" left="10.0" /></BorderPane.margin>
                        </TableView>
                    </center>
                    <bottom>
                        <VBox alignment="TOP_CENTER" prefHeight="120.0" spacing="10.0" BorderPane.alignment="CENTER">
                             <Label text="%faculties.title"><font><Font name="System Bold" size="14.0" /></font></Label>
                            <HBox alignment="CENTER" spacing="10.0">
                                <TextField fx:id="facultyNameField" prefWidth="400.0" promptText="%faculties.form.name.prompt" />
                            </HBox>
                            <HBox alignment="CENTER" spacing="10.0">
                                <Button onAction="#addFaculty" prefWidth="120.0" text="%button.add" />
                                <Button onAction="#updateFaculty" prefWidth="120.0" text="%button.update" />
                                <Button onAction="#deleteFaculty" prefWidth="120.0" text="%button.delete" />
                                <Button onAction="#clearFacultyField" prefWidth="120.0" text="%button.clear" />
                            </HBox>
                            <padding><Insets bottom="10.0" /></padding>
                        </VBox>
                    </bottom>
                </BorderPane>
            </content>
        </Tab>

        <!-- Rooms Tab -->
        <Tab fx:id="roomsTab" text="%tab.rooms">
            <content>
                <BorderPane>
                    <center>
                        <TableView fx:id="roomTableView" BorderPane.alignment="CENTER">
                            <columns>
                                <TableColumn fx:id="roomIdColumn" prefWidth="100.0" text="%rooms.table.id" />
                                <TableColumn fx:id="roomNumberColumn" prefWidth="200.0" text="%rooms.table.number" />
                                <TableColumn fx:id="roomCapacityColumn" prefWidth="150.0" text="%rooms.table.capacity" />
                                <TableColumn fx:id="roomPriceColumn" prefWidth="150.0" text="%rooms.table.price" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <BorderPane.margin><Insets top="10.0" right="10.0" bottom="10.0" left="10.0" /></BorderPane.margin>
                        </TableView>
                    </center>
                    <bottom>
                        <VBox alignment="TOP_CENTER" prefHeight="120.0" spacing="10.0" BorderPane.alignment="CENTER">
                            <children>
                                <Label text="%rooms.title"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <TextField fx:id="roomNumberField" promptText="%rooms.form.number.prompt" />
                                        <TextField fx:id="roomCapacityField" promptText="%rooms.form.capacity.prompt" />
                                        <TextField fx:id="roomPriceField" promptText="%rooms.form.price.prompt" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button onAction="#addRoom" prefWidth="120.0" text="%button.add" />
                                        <Button onAction="#updateRoom" prefWidth="120.0" text="%button.update" />
                                        <Button onAction="#deleteRoom" prefWidth="120.0" text="%button.delete" />
                                        <Button onAction="#clearRoomFields" prefWidth="120.0" text="%button.clear" />
                                    </children>
                                </HBox>
                            </children>
                            <padding><Insets bottom="10.0" /></padding>
                        </VBox>
                    </bottom>
                </BorderPane>
            </content>
        </Tab>

        <!-- Contracts Tab -->
        <Tab fx:id="contractsTab" text="%tab.contracts">
            <content>
                <BorderPane>
                    <center>
                        <TableView fx:id="contractTableView" BorderPane.alignment="CENTER">
                            <columns>
                                <TableColumn fx:id="contractIdColumn" prefWidth="50.0" text="%contracts.table.id" />
                                <TableColumn fx:id="contractStudentColumn" prefWidth="180.0" text="%contracts.table.student" />
                                <TableColumn fx:id="contractRoomColumn" prefWidth="100.0" text="%contracts.table.room" />
                                <TableColumn fx:id="contractStartColumn" prefWidth="120.0" text="%contracts.table.start" />
                                <TableColumn fx:id="contractEndColumn" prefWidth="120.0" text="%contracts.table.end" />
                                <TableColumn fx:id="contractStatusColumn" prefWidth="100.0" text="%contracts.table.status" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <BorderPane.margin><Insets top="10.0" right="10.0" bottom="10.0" left="10.0" /></BorderPane.margin>
                        </TableView>
                    </center>
                    <bottom>
                        <VBox alignment="TOP_CENTER" prefHeight="150.0" spacing="10.0" BorderPane.alignment="CENTER">
                            <children>
                                <Label text="%contracts.title"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="contractStudentComboBox" promptText="%contracts.form.student.prompt" prefWidth="180.0" />
                                        <ComboBox fx:id="contractRoomComboBox" promptText="%contracts.form.room.prompt" prefWidth="100.0" />
                                        <DatePicker fx:id="contractStartDatePicker" prefWidth="120.0" promptText="%contracts.form.start.prompt" />
                                        <DatePicker fx:id="contractEndDatePicker" prefWidth="120.0" promptText="%contracts.form.end.prompt" />
                                        <ComboBox fx:id="contractStatusComboBox" promptText="%contracts.form.status.prompt" prefWidth="100.0" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button onAction="#addContract" prefWidth="120.0" text="%button.add" />
                                        <Button onAction="#updateContract" prefWidth="120.0" text="%button.update" />
                                        <Button onAction="#deleteContract" prefWidth="120.0" text="%button.delete" />
                                        <Button onAction="#clearContractFields" prefWidth="120.0" text="%button.clear" />
                                    </children>
                                </HBox>
                            </children>
                            <padding><Insets bottom="10.0" /></padding>
                        </VBox>
                    </bottom>
                </BorderPane>
            </content>
        </Tab>
    </tabs>
</TabPane>
